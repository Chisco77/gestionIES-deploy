# ======================
# Backend
# ======================

ANONIMIZAR_USUARIOS=false
CONTROL_OPTATIVA4=false
DB_USER=postgres
DB_NAME=gestionIES
VITE_API_URL=/api
VITE_APP_NAME=miIES


# ============================================
#
# 
# PARÁMETROS QUE TENÉIS QUE CAMBIAR
#
#
# ============================================

# Contraseña de la BD
DB_PASSWORD=miPassword

# CORS. Sustituir IP_EQUIPO_DESPLIEGUE por la ip del equipo en la que estáis desplegando la aplicación
ALLOWED_ORIGINS=http://localhost:5173,https://localhost:5173,https://IP_EQUIPO_DESPLIEGUE


# Sustituir IP_LDAP por la IP de vuestro LDAP
LDAP_URL=ldap://IP_LDAP:389

# ======================
# Frontend VITE variables
#
# 
# ======================

# Sustituir IP_EQUIPO_DESPLIEGUE por la ip del equipo en el que se ha instalado gestionIES
VITE_SERVER_URL=https://IP_EQUIPO_DESPLIEGUE   

# Introducid nombre de vuestro centro y dirección 
VITE_IES_NAME=
VITE_DIRECCION_LINEA_1=
VITE_DIRECCION_LINEA_2=
VITE_DIRECCION_LINEA_3=
VITE_DIRECCION_LINEA_4=
VITE_DIRECCION_LINEA_5=

